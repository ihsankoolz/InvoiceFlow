# ============================================================
# InvoiceFlow — Environment Variables
# Copy this file to .env and fill in real values where needed
# ============================================================

# --- Shared Database Credentials ---
MYSQL_ROOT_PASSWORD=password

# --- User Service (:5000) ---
USER_DB_URL=mysql+pymysql://root:password@user-db:3306/user_db
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Invoice Service (:5001) ---
INVOICE_DB_URL=mysql+pymysql://root:password@invoice-db:3306/invoice_db
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=invoices

# --- Marketplace Service (:5002) ---
MARKET_DB_URL=mysql+pymysql://root:password@market-db:3306/market_db

# --- Bidding Service (:5003) ---
BIDDING_DB_URL=mysql+pymysql://root:password@bidding-db:3306/bidding_db

# --- Payment Service (:5004 / :50051) ---
PAYMENT_DB_URL=mysql://root:password@payment-db:3306/payment_db
PAYMENT_GRPC_PORT=50051
PAYMENT_REST_PORT=5004

# --- Notification Service (:5005) ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=notifications@invoiceflow.dev

# --- RabbitMQ (shared) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# --- Invoice Orchestrator (:5010) ---
USER_SERVICE_URL=http://user-service:5000
INVOICE_SERVICE_URL=http://invoice-service:5001
MARKETPLACE_SERVICE_URL=http://marketplace-service:5002
ACRA_WRAPPER_URL=http://acra-wrapper:5007
TEMPORAL_HOST=temporal:7233

# --- Bidding Orchestrator (:5011) ---
BIDDING_SERVICE_URL=http://bidding-service:5003
STRIPE_WRAPPER_URL=http://stripe-wrapper:5008
PAYMENT_SERVICE_GRPC=payment-service:50051
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# --- Loan Orchestrator (:5012) ---
# Uses PAYMENT_SERVICE_GRPC, STRIPE_WRAPPER_URL, RABBITMQ_URL from above

# --- ACRA Wrapper (:5007) ---
DATA_GOV_API_URL=https://data.gov.sg/api/action/datastore_search
ACRA_DATASET_RESOURCE_ID=your-acra-resource-id

# --- Stripe Wrapper (:5008) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_SUCCESS_URL=http://localhost:8080/payment/success
STRIPE_CANCEL_URL=http://localhost:8080/payment/cancel

# --- Temporal Worker ---
REPAYMENT_WINDOW_SECONDS=120

# --- MinIO (:9000 / :9001) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
