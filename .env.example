# InvoiceFlow Environment Variables
# Copy this file to .env and fill in your actual values

# ====================================
# External Services
# ====================================

# OutSystems API
OUTSYSTEMS_API_URL=https://your-app.outsystemscloud.com/InvoiceValidator/rest/v1
OUTSYSTEMS_API_KEY=your_api_key_here

# RabbitMQ
RABBITMQ_URL=amqp://rabbitmq:5672
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# ====================================
# Database Configuration
# ====================================

# MySQL Root Password (used by all databases)
MYSQL_ROOT_PASSWORD=root_password_change_in_production

# Database Hosts (Docker service names)
DB_USER_HOST=mysql-user
DB_INVOICE_HOST=mysql-invoice
DB_MARKETPLACE_HOST=mysql-marketplace
DB_BIDDING_HOST=mysql-bidding
DB_PAYMENT_HOST=mysql-payment

# Database Names
DB_USER_NAME=user_db
DB_INVOICE_NAME=invoice_db
DB_MARKETPLACE_NAME=marketplace_db
DB_BIDDING_NAME=bidding_db
DB_PAYMENT_NAME=payment_db

# ====================================
# Authentication & Security
# ====================================

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_please

# JWT Expiry (in seconds)
JWT_EXPIRY=86400  # 24 hours

# Bcrypt Salt Rounds
BCRYPT_ROUNDS=10

# ====================================
# API Gateway (KONG)
# ====================================

# KONG Admin API
KONG_ADMIN_URL=http://kong:8001

# KONG Proxy
KONG_PROXY_URL=http://localhost:8000

# ====================================
# Service Ports
# ====================================

USER_SERVICE_PORT=5000
INVOICE_SERVICE_PORT=5001
MARKETPLACE_SERVICE_PORT=5002
BIDDING_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004

# gRPC Port (Payment Service)
PAYMENT_GRPC_PORT=50051

# ====================================
# Frontend
# ====================================

FRONTEND_PORT=8080
REACT_APP_API_URL=http://localhost:8000/api

# ====================================
# Development Settings
# ====================================

# Environment (development, staging, production)
NODE_ENV=development

# Debug Mode
DEBUG=true

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# ====================================
# Rate Limiting (KONG)
# ====================================

# Requests per minute per user
RATE_LIMIT_PER_MINUTE=100

# Bid rate limit (per investor)
BID_RATE_LIMIT_PER_MINUTE=10

# ====================================
# Cron Job Settings
# ====================================

# Auction Closer - runs every N hours
AUCTION_CLOSER_INTERVAL_HOURS=1

# Maturity Checker - cron expression (daily at midnight)
MATURITY_CHECKER_CRON="0 0 * * *"

# ====================================
# Business Logic Configuration
# ====================================

# Minimum invoice amount
MIN_INVOICE_AMOUNT=1000

# Maximum invoice amount
MAX_INVOICE_AMOUNT=10000000

# Minimum bid period (hours)
MIN_BID_PERIOD_HOURS=1

# Maximum bid period (hours)
MAX_BID_PERIOD_HOURS=720

# Repayment window (hours)
REPAYMENT_WINDOW_HOURS=24

# ====================================
# Docker Configuration
# ====================================

# Docker Compose Project Name
COMPOSE_PROJECT_NAME=invoiceflow

# Docker Network
DOCKER_NETWORK=invoiceflow-network

# ====================================
# Testing
# ====================================

# Test Database (separate from development)
TEST_DB_NAME=invoiceflow_test

# Test User Credentials
TEST_BUSINESS_EMAIL=bakery@test.com
TEST_BUSINESS_PASSWORD=BakeryPass123
TEST_INVESTOR_EMAIL=investor@test.com
TEST_INVESTOR_PASSWORD=InvestPass123
