# ============================================================
# InvoiceFlow — Environment Variables
# Copy this file to .env and fill in real values.
# Generate JWT_SECRET with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# --- Auth (User Service + Kong JWT plugin) ---
JWT_SECRET=your-jwt-secret-change-in-production

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Webhook signing secret — from `stripe listen --print-secret` or Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# --- Notification Service ---
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- ACRA / Data.gov.sg ---
DATA_GOV_API_KEY=
# Set to true to skip real UEN validation in local dev
MOCK_UEN_VALIDATION=false

# --- OutSystems Activity Log ---
OUTSYSTEMS_API_URL=https://your-outsystems-url/api

# --- Demo Mode (speeds up Temporal workflow timers for live presentations) ---
# Set DEMO_MODE=true on EC2 before the demo, then revert afterwards
DEMO_MODE=false
DEMO_AUCTION_SECONDS=90            # Auction duration (default 90s = 1.5 min)
DEMO_LOAN_MATURITY_SECONDS=90      # Time until loan is marked DUE (default 90s = 1.5 min)
DEMO_REPAYMENT_WINDOW_SECONDS=60   # Window to repay before OVERDUE (default 60s)
ANTI_SNIPE_WINDOW_SECONDS=300      # Anti-snipe trigger window (set to 15 in demo mode)
