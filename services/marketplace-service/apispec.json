      "get": {
        "tags": [
          "Public Listings"
        ],
        "summary": "Get a single listing",
        "description": "Returns a single active listing by ID.\n\nCalled by Bidding Orchestrator at step B11 to check the anti-snipe window.\nReturns 404 if not found.",
        "operationId": "get_listing_api_listings__listing_id__get",
        "parameters": [
          {
            "name": "listing_id",
            "in": "path",
            "required": true,
