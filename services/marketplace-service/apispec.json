    "/api/listings": {
      "get": {
        "tags": [
          "Public Listings"
        ],
        "summary": "Get marketplace listings",
        "description": "Returns active auction listings from the read model for the frontend marketplace page.\n\nSingle DB query — no calls to invoice-service or bidding-service.\nFilters: urgency_level, search (invoice_token / debtor_name / debtor_uen), seller_id.\nOnly returns listings with status=ACTIVE and deadline in the future.",
        "operationId": "get_listings_api_listings_get",
        "parameters": [
          {
            "name": "urgency_level",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Urgency Level"
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Search"
            }
          },
          {
            "name": "seller_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Seller Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
