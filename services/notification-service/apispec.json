{
  "openapi": "3.1.0",
  "info": {
    "title": "Notification Service",
    "description": "Listens for all events via RabbitMQ and sends email (Resend) + real-time WebSocket notifications to the frontend via Nginx.",
    "version": "1.0.0"
  },
  "paths": {
    "/metrics": {
      "get": {
        "summary": "Metrics",
