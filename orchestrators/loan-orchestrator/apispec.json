{
  "openapi": "3.1.0",
  "info": {
    "title": "Loan Orchestrator",
    "description": "Orchestrates loan repayment via Stripe and confirms repayment via Temporal. Also exposes loan listing for the frontend.",
    "version": "1.0.0"
  },
  "paths": {
    "/metrics": {
      "get": {
        "summary": "Metrics",
        "description": "Endpoint that serves Prometheus metrics.",
        "operationId": "metrics_metrics_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          }
        }
      }
    },
    "/api/loans": {
      "get": {
        "tags": [
          "Loans"
        ],
        "summary": "List loans by investor or seller",
        "description": "Returns loans filtered by investor_id or seller_id.",
        "operationId": "list_loans_api_loans_get",
        "parameters": [
          {
            "name": "investor_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Investor Id"
            }
          },
          {
            "name": "seller_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Seller Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/loans/{loan_id}/repay": {
      "post": {
        "tags": [
          "Repayment"
        ],
        "summary": "Initiate loan repayment via Stripe",
        "description": "Gets loan details via gRPC, creates Stripe checkout session via Stripe Wrapper.",
        "operationId": "repay_loan_api_loans__loan_id__repay_post",
        "parameters": [
          {
            "name": "loan_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Loan Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RepayLoanRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutUrlResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/loans/{loan_id}/confirm-repayment": {
      "post": {
        "tags": [
          "Repayment"
        ],
        "summary": "Confirm loan repayment after Stripe payment",
        "description": "Updates loan status to REPAID via gRPC, publishes loan.repaid event.",
        "operationId": "confirm_repayment_api_loans__loan_id__confirm_repayment_post",
        "parameters": [
          {
            "name": "loan_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Loan Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfirmRepaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepaymentResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CheckoutUrlResponse": {
        "properties": {
          "checkout_url": {
            "type": "string",
            "title": "Checkout Url"
          }
        },
        "type": "object",
        "required": [
          "checkout_url"
        ],
        "title": "CheckoutUrlResponse"
      },
      "ConfirmRepaymentRequest": {
        "properties": {
          "stripe_session_id": {
            "type": "string",
            "title": "Stripe Session Id"
          }
        },
        "type": "object",
        "required": [
          "stripe_session_id"
        ],
        "title": "ConfirmRepaymentRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RepayLoanRequest": {
        "properties": {
          "seller_id": {
            "type": "integer",
            "title": "Seller Id"
          }
        },
        "type": "object",
        "required": [
          "seller_id"
        ],
        "title": "RepayLoanRequest"
      },
      "RepaymentResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "loan_id": {
            "type": "string",
            "title": "Loan Id"
          }
        },
        "type": "object",
        "required": [
          "status",
          "loan_id"
        ],
        "title": "RepaymentResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "tags": [
    {
      "name": "Loans",
      "description": "List loans by investor or seller"
    },
    {
      "name": "Repayment",
      "description": "Initiate and confirm loan repayment — Scenario 3 repayment flow"
    },
    {
      "name": "Health",
      "description": "Health check"
    }
  ]
}