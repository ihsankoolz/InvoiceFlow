{
  "title": "InvoiceFlow Overview",
  "uid": "invoiceflow-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{job=\"invoiceflow-services\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_requests_total{job=\"invoiceflow-services\"}[1m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_requests_total{job=\"invoiceflow-services\", status_code=~\"5..\"}[1m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "HTTP Latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (instance, le) (rate(http_request_duration_seconds_bucket{job=\"invoiceflow-services\"}[5m])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "HTTP Latency p50 (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (instance, le) (rate(http_request_duration_seconds_bucket{job=\"invoiceflow-services\"}[5m])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "Payment gRPC Operations (ops/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (method) (rate(payment_grpc_operations_total{status=\"success\"}[1m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "title": "Payment gRPC Errors (ops/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (method) (rate(payment_grpc_operations_total{status=\"error\"}[1m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "title": "RabbitMQ Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue!~\".*[.]dlq\"}",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 9,
      "title": "DLQ Depth (Dead Letter Queues)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=~\".*[.]dlq\"}",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}
